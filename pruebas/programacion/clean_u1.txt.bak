variables  o  especificar  dónde  comienza  el  código  fuente  o  el  método  principal  del
programa:  boolean,  int,  double,  char,  public,  class,  void,  etc.
abstracto,  continuar,  para,  nuevo,  cambiar,  afirmar,  predeterminado,  ir  a,
paquete,  sincronizado,  booleano,  hacer,  si,  privado,  esto,  romper,  doble,
implementa,  protegido,  lanzar,  byte,  si  no,  importar,  público,  lanza,  caso,
enumeración,  instancia  de,  devolver,  transitorio,  atrapar,  extender,  entero,
